# OpenStack authentication
OS_AUTH_URL=https://your-openstack-cluster:5000/v3
OS_USERNAME=your-username
OS_PASSWORD=your-password
OS_PROJECT_NAME=your-project
OS_PROJECT_DOMAIN_NAME=Default

# OpenStack application credential (preferred over username/password)
OS_APPLICATION_CREDENTIAL_ID=your-app-credential-id
OS_APPLICATION_CREDENTIAL_SECRET=your-app-credential-secret

# SSH public key injected into the baremetal user on the VM
SSH_PUBLIC_KEY=ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAAB... user@host

# GitHub token (used for repo management)
GITHUB_TOKEN=your-github-token
